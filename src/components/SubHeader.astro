---
const topics = [
  { name: "Politics", href: "/topics/politics" },
  { name: "Tech", href: "/topics/tech" },
  { name: "Sports", href: "/topics/sports" },
  { name: "Business", href: "/topics/business" },
  { name: "Science", href: "/topics/science" },
  { name: "Culture", href: "/topics/culture" },
  { name: "Health", href: "/topics/health" },
  { name: "All Topics", href: "/topics" },
];
---

<div class="flex justify-center w-full px-6 md:px-10 overflow-hidden">
  <div class="inline-flex items-center bg-red-700/90 backdrop-blur-xl border border-red-500/30 rounded-full px-8 py-2.5 shadow-2xl overflow-x-auto hide-scrollbar max-w-full animate">
    <nav class="flex items-center gap-8 md:gap-8 whitespace-nowrap">
      {topics.map((topic, index) => (
        <a 
          href={topic.href} 
          class={`text-[9px] font-bold tracking-[0.1em] uppercase text-white hover:text-red-200 transition-all active:scale-95 
            ${index === 2 ? "hidden mini:inline-block lg:inline-block" : ""} 
            ${index >= 3 && index < topics.length - 1 ? "hidden lg:inline-block" : ""}`}
        >
          {topic.name}
        </a>
      ))}
    </nav>
  </div>
</div>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
