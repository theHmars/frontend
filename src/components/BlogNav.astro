---
type Props = {
  activePage?: 'home' | 'categories' | 'about' | 'changelog' | 'landing' | 'rules';
};

const { activePage } = Astro.props;
---

<nav class="flex flex-nowrap items-center gap-1.5 sm:gap-3 md:gap-6 text-xs tracking-[0.1em] md:tracking-[0.2em] uppercase font-medium overflow-x-auto no-scrollbar py-1">
  <a href="/archives" class={`flex-shrink-0 rounded-full border px-3 py-1.5 transition-all duration-300 ${activePage === 'home' ? 'border-neutral-800 bg-neutral-950 text-white' : 'border-transparent text-neutral-400 hover:border-neutral-900 hover:text-white'}`}>
    Home
  </a>
  <a href="/categories" class={`flex-shrink-0 rounded-full border px-3 py-1.5 transition-all duration-300 ${activePage === 'categories' ? 'border-neutral-800 bg-neutral-950 text-white' : 'border-transparent text-neutral-400 hover:border-neutral-900 hover:text-white'}`}>
    Categories
  </a>
  <a href="/about" class={`flex-shrink-0 rounded-full border px-3 py-1.5 transition-all duration-300 ${activePage === 'about' ? 'border-neutral-800 bg-neutral-950 text-white' : 'border-transparent text-neutral-400 hover:border-neutral-900 hover:text-white'}`}>
    About
  </a>
  <span class="text-neutral-800 select-none flex-shrink-0">|</span>
  <a href="/" class={`flex-shrink-0 flex items-center justify-center rounded-full border px-3 py-1.5 transition-all duration-300 ${activePage === 'landing' ? 'border-neutral-800 bg-neutral-950 text-white' : 'border-transparent text-neutral-400 hover:border-neutral-900 hover:text-white'}`} aria-label="Back to landing">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left"><path d="m15 18-6-6 6-6"/></svg>
  </a>
</nav>
