---
import { getCollection } from "astro:content";
import { normalizeTag } from "@lib/utils";

const allPosts = await getCollection("blog", (post) => !post.data.draft);

// Calculate Trending Tags
const allTags = allPosts.flatMap(post => post.data.tags || []);
const tagCounts = allTags.reduce((acc: any, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {});
const trendingTags = Object.entries(tagCounts)
  .sort((a: any, b: any) => b[1] - a[1])
  .slice(0, 8)
  .map(t => t[0]);
---

<>
    {/* SUPPORT MISSION */}
    <div class="rounded-3xl border border-sky-900/50 bg-sky-950/10 p-8 space-y-6 relative overflow-hidden group">
        <div class="absolute -right-4 -top-4 text-red-600/10 transition-transform duration-700 group-hover:scale-110 group-hover:-rotate-12">
            <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        </div>
        <h3 class="text-xs font-bold tracking-[0.3em] uppercase text-red-500">Support the Mission</h3>
        <p class="text-xs font-light leading-relaxed text-neutral-400">
            thehmars is an independent portal. Our donation system has been temporarily deactivated while we migrate our database to Supabase. Thank you for your continued support!
        </p>
        <a href="#" onclick="alert('The donation system has been temporarily paused while we upgrade our internal systems. Please check back later!'); return false;" class="flex items-center justify-center h-12 w-full bg-white text-black rounded-xl text-[10px] font-bold tracking-[0.2em] uppercase transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] cursor-pointer">
            Make a Contribution
        </a>
    </div>

    {/* TRENDING TOPICS */}
    <div class="space-y-6">
        <h3 class="text-[10px] font-bold tracking-[0.5em] uppercase text-neutral-500 border-b border-neutral-900 pb-2">Trending Topics</h3>
        <div class="flex flex-wrap gap-2">
            {trendingTags.map((tag: any) => (
                <a href={`/topics/${normalizeTag(tag)}`} class="px-3 py-1.5 rounded-lg border border-neutral-800 bg-neutral-900/40 text-[9px] uppercase tracking-widest text-neutral-400 hover:text-white hover:border-neutral-600 transition-all">
                    #{tag}
                </a>
            ))}
        </div>
    </div>

    {/* NEWSLETTER SIGNUP */}
    <div class="rounded-3xl border border-neutral-800 bg-neutral-950 p-8 space-y-6">
        <h3 class="text-xs font-bold tracking-[0.3em] uppercase text-white">Daily Dispatch</h3>
        <p class="text-xs font-light leading-relaxed text-neutral-500">
            Get the most important stories delivered to your inbox every morning.
        </p>
        <div class="space-y-3">
            <input 
                type="email" 
                placeholder="EMAIL ADDRESS" 
                class="w-full h-11 bg-neutral-900 border border-neutral-800 rounded-xl px-4 text-[10px] tracking-widest text-white focus:outline-none focus:border-neutral-600 transition-colors"
            />
            <button onclick="alert('Newsletter subscriptions are temporarily offline while we upgrade our database. Please check back soon!'); return false;" class="w-full h-11 border border-neutral-800 text-neutral-400 rounded-xl text-[10px] font-bold tracking-[0.2em] uppercase hover:bg-white hover:text-black hover:border-white transition-all">
                Subscribe
            </button>
        </div>
    </div>

    {/* AD SPACE / SPONSORSHIP PLACEHOLDER */}
    <div class="rounded-3xl border border-dashed border-neutral-800 bg-neutral-900/5 p-8 flex flex-col items-center justify-center text-center space-y-4 min-h-[220px] group transition-colors hover:border-neutral-700">
        <div class="text-neutral-800 group-hover:text-neutral-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="m7 11 2 2 4-4"/></svg>
        </div>
        <div class="space-y-1">
            <p class="text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-600">Sponsorship</p>
            <p class="text-[9px] font-light leading-relaxed text-neutral-700 max-w-[180px]">
                Promote your project or community event here.
            </p>
        </div>
        <a href="/contact" class="text-[9px] font-bold tracking-[0.2em] uppercase text-neutral-500 hover:text-white transition-colors border-b border-neutral-900 hover:border-white pb-0.5">
            Inquire
        </a>
    </div>
