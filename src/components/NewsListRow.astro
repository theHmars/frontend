---
type Props = {
  href: string;
  date: string;
  title: string;
  image?: string;
  category?: string;
};

const { href, date, title, image, category } = Astro.props;
const displayImage = image || "/assets/fallback.webp";
---

<li class="group list-none">
  <a
    href={href}
    class="flex items-center gap-4 rounded-2xl border border-transparent p-2 transition-all duration-300 hover:border-neutral-900/50 hover:bg-neutral-950/40"
  >
    {/* Small Thumbnail */}
    <div class="h-16 w-16 flex-shrink-0 overflow-hidden rounded-xl bg-neutral-900 md:h-20 md:w-20">
      <img
        src={displayImage}
        alt={title}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110 grayscale-[0.5] group-hover:grayscale-0"
      />
    </div>

    {/* Content */}
    <div class="flex min-w-0 flex-col gap-1">
      <div class="flex items-center gap-3">
        <span class="text-[8px] font-bold tracking-[0.2em] uppercase text-red-600/80">
          {category}
        </span>
        <time class="text-[8px] font-medium tracking-[0.1em] text-neutral-700 uppercase">
          {date}
        </time>
      </div>
      <h3 class="line-clamp-2 text-sm font-medium tracking-tight text-neutral-300 transition-colors group-hover:text-white md:text-base">
        {title}
      </h3>
    </div>
    
    <div class="ml-auto hidden pr-4 opacity-0 transition-all duration-300 group-hover:translate-x-1 group-hover:opacity-100 md:block text-neutral-700">
        ↗
    </div>
  </a>
</li>
