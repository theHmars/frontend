---
type Badge = {
  label: string;
  tone?: "muted" | "solid" | "accent";
};

type Props = {
  href: string;
  date: string;
  title: string;
  description?: string;
  image?: string;
  region?: string;
  badges?: Badge[];
  isRedacted?: boolean;
  isPrivate?: boolean;
};

const { href, date, title, description, image, region, badges = [], isRedacted, isPrivate } = Astro.props;
const isRestricted = isRedacted || isPrivate;

const toneClasses: Record<NonNullable<Badge["tone"]>, string> = {
  muted: "border-neutral-900 text-neutral-500",
  solid: "border-neutral-800 bg-neutral-900 text-white",
  accent: "border-neutral-800/80 text-red-400/70",
};
---

<li class="group">
  <a
    href={href}
    class={`grid grid-cols-1 gap-3 rounded-2xl border border-transparent px-0 py-1 transition-all duration-300 md:grid-cols-[100px_1fr_24px] md:items-center md:gap-8 md:px-6 md:py-6 ${"hover:border-neutral-900/80 hover:bg-neutral-950/40"}`}
  >
    {/* IMAGE THUMBNAIL */}
    <div class="hidden md:block w-24 h-16 rounded-xl overflow-hidden bg-neutral-900 border border-neutral-800 transition-all duration-500 group-hover:border-neutral-700">
        {image ? (
            <img 
                src={image} 
                alt={title}
                class="w-full h-full object-cover opacity-50 grayscale group-hover:opacity-100 group-hover:grayscale-0 transition-all duration-500"
            />
        ) : (
            <div class="w-full h-full flex items-center justify-center bg-neutral-950/80 text-neutral-800 group-hover:text-neutral-600 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
                    <line x1="4" x2="4" y1="22" y2="15"/>
                </svg>
            </div>
        )}
    </div>

    <div class="min-w-0 space-y-2 border-l border-neutral-900 pl-5 transition-all duration-300 group-hover:border-neutral-800">
      <div class="flex flex-col lg:flex-row lg:items-center gap-2 lg:gap-3">
        <div class="flex items-center gap-3">
            <time class="text-[9px] font-bold tracking-[0.2em] text-neutral-600 uppercase whitespace-nowrap">
                {date}
            </time>
            <h2 class="text-lg font-medium tracking-tight text-neutral-200 uppercase transition-all duration-300 group-hover:text-white md:text-xl flex items-center gap-2.5 line-clamp-1">
            {title}
            {isRestricted && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-600 group-hover:text-neutral-400 transition-colors"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            )}
            </h2>
        </div>
        
        {region && (
          <span class={`rounded-full border px-2 py-0.5 text-[8px] font-bold tracking-[0.25em] uppercase ${toneClasses["accent"]}`}>
            {region}
          </span>
        )}
        
        {badges.length > 0 && (
          <div class="flex flex-wrap items-center gap-2">
            {badges.map((badge) => (
              <span class={`rounded-full border px-2 py-0.5 text-[8px] font-bold tracking-[0.25em] uppercase ${toneClasses[badge.tone || "muted"]}`}>
                {badge.label}
              </span>
            ))}
          </div>
        )}
      </div>
      {isRestricted ? (
         <p class="max-w-xl text-[10px] font-light tracking-[0.1em] uppercase text-neutral-700 italic">
            {isRedacted ? "Content Redacted" : "Entry set to private"}
         </p>
      ) : (
        description && (
          <p class="max-w-2xl text-xs font-light leading-relaxed text-neutral-500 transition-all duration-300 group-hover:text-neutral-400 line-clamp-1">
            {description}
          </p>
        )
      )}
    </div>

    <span class="hidden text-neutral-800 transition-all duration-300 group-hover:translate-x-1 group-hover:text-neutral-500 md:block">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </span>
  </a>
</li>
