---
import BlogLayout from "@layouts/BlogLayout.astro";
import Container from "@components/Container.astro";
import { SITE } from "@consts";
---

<BlogLayout title="404" description={SITE.DESCRIPTION}>
  <Container>
    <div class="pt-32 pb-20 flex flex-col items-center justify-center text-center space-y-12 animate">
      
      <div class="space-y-4">
        <h1 class="text-7xl md:text-9xl font-sans font-bold tracking-[0.4em] uppercase text-red-600/20 group-hover:text-red-600 transition-colors duration-1000">
          404
        </h1>
        <div class="h-[1px] w-12 bg-red-900/50 mx-auto"></div>
        <p class="text-red-500 text-[10px] md:text-xs tracking-[0.3em] uppercase font-bold">
          Lost in the Node
        </p>
      </div>

      <div class="max-w-md text-neutral-500 text-xs tracking-[0.15em] leading-relaxed font-light italic opacity-70 px-4">
        The page you are looking for has either been moved, deleted, or never existed in this digital space.
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-6 w-full max-w-sm mx-auto">
        <button 
          id="back-button"
          type="button"
          class="w-full sm:w-auto sm:min-w-[110px] px-6 py-2.5 rounded-lg border border-neutral-800 text-[10px] tracking-[0.2em] uppercase font-bold text-neutral-500 hover:border-neutral-700 hover:text-white transition-all duration-300 bg-neutral-950/50"
        >
          Go Back
        </button>
        
        <a 
          href="/" 
          class="w-full sm:w-auto sm:min-w-[110px] px-6 py-2.5 rounded-lg border border-neutral-800 text-[10px] tracking-[0.2em] uppercase font-bold text-neutral-500 hover:border-neutral-700 hover:text-white transition-all duration-300 bg-neutral-950/50"
        >
          Home
        </a>

        <a 
          href="/archives" 
          class="w-full sm:w-auto sm:min-w-[110px] px-6 py-2.5 rounded-lg border border-neutral-800 text-[10px] tracking-[0.2em] uppercase font-bold text-neutral-500 hover:border-neutral-700 hover:text-white transition-all duration-300 bg-neutral-950/50"
        >
          Archives
        </a>
      </div>

    </div>
  </Container>
</BlogLayout>

<script>
  function setupNotFoundBackButton() {
    const backButton = document.getElementById("back-button");
    if (!backButton || backButton.dataset.ready === "true") return;

    backButton.dataset.ready = "true";

    backButton.addEventListener("click", () => {
      if (window.history.length > 1) {
        window.history.back();
        return;
      }

      window.location.href = "/archives";
    });
  }

  document.addEventListener("astro:page-load", setupNotFoundBackButton);
  setupNotFoundBackButton();
</script>

<style>
  .animate {
    animation: reveal 1s cubic-bezier(0.16, 1, 1, 1) forwards;
  }

  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
