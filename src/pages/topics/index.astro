---
import { getCollection } from "astro:content";
import BlogLayout from "@layouts/BlogLayout.astro";
import Container from "@components/Container.astro";
import { normalizeTag } from "@lib/utils";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const allEntries = [...posts];

// Use majorTag as primary discovery source alongside predefined static lists
const predefinedTags = [
  "Politics", "Sports", "Business", "Tech", "Science", "Culture", "Health", 
  "Education", "Weather", "Entertainment", "Environment", "Celebrity", "Uncategorized"
];

const dynamicTags = allEntries.flatMap((entry) => {
  const mainTag = entry.data.majorTag;
  const otherTags = (entry.data.tags || []).map(normalizeTag);
  return mainTag ? [mainTag, ...otherTags] : otherTags;
});

const tags = [...new Set([...predefinedTags, ...dynamicTags])].sort();

// Get counts for each tag (checking both majorTag and tags array)
const tagCounts = tags.reduce((acc, tag) => {
  const slug = normalizeTag(tag);
  acc[tag] = allEntries.filter((entry) => {
    const isMainMatch = entry.data.majorTag === tag || normalizeTag(entry.data.majorTag || "") === slug;
    const isOtherMatch = entry.data.tags?.some((t: string) => normalizeTag(t) === slug);
    return isMainMatch || isOtherMatch;
  }).length;
  return acc;
}, {} as Record<string, number>);

// Desk Descriptions mapping
const topicDescriptions: Record<string, string> = {
  "politics": "Policy changes, elections, and government actions shaping society.",
  "tech": "Innovations, cybersecurity, and the digital economy.",
  "sports": "Scores, tournaments, and athletic achievements.",
  "business": "Markets, mergers, and economic trends.",
  "science": "Discoveries, research, and natural phenomena.",
  "culture": "Arts, festivals, and societal movements.",
  "health": "Medical initiatives, wellness, and public health policies.",
  "weather": "Monsoon forecasts, weather patterns, and meteorological alerts.",
  "entertainment": "Movie releases, pop culture, music, and performance arts.",
  "environment": "Conservation efforts, ecological developments, and climate actions.",
  "celebrity": "Biographies, profiles, and coverage of notable figures.",
};

const getDeskDescription = (tag: string) => {
  return topicDescriptions[tag] || "Aggregated reports and updates carefully curated from multiple sources.";
};

// Sort tags by count so the most populated desks appear first
const sortedTags = tags.sort((a, b) => tagCounts[b] - tagCounts[a]);
---

<BlogLayout title="Topics" description="Browse all news coverage by topic">
  <div class="bg-neutral-950/50 backdrop-blur-2xl border border-neutral-800 rounded-[2rem] md:rounded-[3rem] shadow-2xl overflow-hidden mt-0">
    <Container>
      <div class="pt-24 pb-20 space-y-24 animate show">
      
      {/* Page Header */}
      <div class="flex flex-col md:items-center text-left md:text-center gap-6 border-b border-neutral-900 pb-12 max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-white uppercase">Coverage Desks</h1>
        <p class="text-neutral-400 text-sm md:text-base font-light leading-relaxed">
          Explore our comprehensive directory of news topics. Each desk aggregates reporting across Local, National, and International scopes to give you the full picture.
        </p>
        <div class="pt-4">
            <span class="inline-block border border-neutral-800 rounded-full px-4 py-1.5 text-[10px] tracking-[0.3em] uppercase text-neutral-500 font-bold">
                {tags.length} Active Desks
            </span>
        </div>
      </div>

      {/* Desk Grid */}
      <section class="space-y-10">
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 md:gap-8">
          {sortedTags.map((tag) => {
            const slug = normalizeTag(tag);
            return (
              <a
                href={`/topics/${slug}`}
              class="group relative flex flex-col justify-between h-full rounded-[2rem] border border-neutral-900 bg-neutral-950/40 p-8 transition-all duration-500 hover:border-neutral-700 hover:bg-neutral-900 overflow-hidden"
            >
              {/* Background Accent */}
              <div class="absolute -right-10 -top-10 text-neutral-800/10 transition-transform duration-700 group-hover:scale-110 group-hover:-rotate-12 group-hover:text-red-900/5">
                <svg xmlns="http://www.w3.org/2000/svg" width="160" height="160" viewBox="0 0 24 24" fill="currentColor"><path d="M4 22h14a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"/></svg>
              </div>

              <div class="relative z-10 space-y-6">
                <div class="flex justify-between items-start">
                    <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-neutral-300 group-hover:text-white transition-colors uppercase">
                    {tag}
                    </h2>
                    <span class="flex items-center justify-center w-10 h-10 rounded-full border border-neutral-800 bg-black text-xs text-neutral-500 group-hover:border-neutral-600 group-hover:text-white transition-all">
                        {tagCounts[tag]}
                    </span>
                </div>
                <p class="text-sm font-light leading-relaxed text-neutral-500 group-hover:text-neutral-400 transition-colors">
                    {getDeskDescription(tag)}
                </p>
              </div>
              
              <div class="relative z-10 mt-12 pt-6 border-t border-neutral-900 flex items-center justify-between">
                <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-neutral-600 group-hover:text-red-400 transition-colors">
                    Access Desk
                </span>
                <span class="text-neutral-600 group-hover:text-white transition-transform group-hover:translate-x-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          );
        })}
        </div>
      </section>

      {/* Editorial Standards / Info Banner */}
      <section class="rounded-[2.5rem] border border-sky-900/50 bg-sky-950/10 p-10 md:p-16 relative overflow-hidden flex flex-col md:flex-row items-center gap-12">
         <div class="flex-1 space-y-6">
            <h3 class="text-xs font-bold tracking-[0.4em] uppercase text-sky-500">Editorial Strategy</h3>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white uppercase">Cross-Scope Curation</h2>
            <p class="text-neutral-400 text-sm md:text-base font-light leading-relaxed max-w-2xl">
                I believe that understanding a topic requires looking at it from multiple angles. These coverage desks intentionally aggregate Local, National, and International reports to provide you with a comprehensive, curated view of how these issues impact different communities.
            </p>
         </div>
         <div class="shrink-0">
             <a href="/about" class="inline-flex items-center justify-center h-14 px-8 bg-white text-black rounded-xl text-[10px] font-bold tracking-[0.2em] uppercase transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]">
                Read The Mission
            </a>
         </div>
      </section>

      {/* Submit a Tip Banner */}
      <section class="rounded-[2.5rem] border border-neutral-800 bg-neutral-900/20 p-10 md:p-16 text-center space-y-8 max-w-4xl mx-auto">
         <div class="mx-auto w-16 h-16 rounded-full bg-neutral-900 border border-neutral-700 flex items-center justify-center text-neutral-400 mb-4">
             <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
         </div>
         <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-white uppercase">Suggest a Source</h2>
         <p class="text-neutral-500 text-sm md:text-base font-light leading-relaxed max-w-xl mx-auto">
            This portal relies on discovering high-quality reporting. If you know of an important news source, a local publication, or a specific article that should be aggregated here, let me know.
         </p>
         <a href="/contact" class="inline-flex items-center justify-center h-14 px-8 border border-neutral-700 text-white rounded-xl text-[10px] font-bold tracking-[0.2em] uppercase transition-all duration-300 hover:bg-white hover:text-black">
            Submit a Tip
        </a>
      </section>

    </div>
  </Container>
</div>
</BlogLayout>
