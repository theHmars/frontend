---
import { getCollection } from "astro:content";
import BlogLayout from "@layouts/BlogLayout.astro";
import Container from "@components/Container.astro";
import FeedCard from "@components/FeedCard.astro";
import Ticker from "@components/Ticker.astro";
import SidebarWidgets from "@components/SidebarWidgets.astro";
import { REGIONS } from "@consts";

export async function getStaticPaths() {
  return REGIONS.map((region) => ({
    params: { region: region.toLowerCase().replace(/ /g, "-") },
    props: { regionName: region },
  }));
}

const { regionName } = Astro.props;
const regionSlug = regionName.toLowerCase().replace(/ /g, "-");

const allPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft && post.data.category === "Local" && post.data.region === regionName)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// TIER 1: State Headline Mosaic (Multi-Hero logic)
const heroStories = allPosts.slice(0, 3);
const heroIds = new Set(heroStories.map(p => p.id));
const remainingPosts = allPosts.filter(p => !heroIds.has(p.id));

const mainHero = heroStories[0];
const secondaryHeroes = heroStories.slice(1);

// TIER 2: Grid
const gridPosts = remainingPosts.slice(0, 6);

// TIER 3: List
---

<BlogLayout title={`${regionName} News`} description={`Latest reports and stories from ${regionName}.`}>
  <div class="bg-neutral-950/50 backdrop-blur-2xl border border-neutral-800 rounded-[2rem] md:rounded-[3rem] shadow-2xl overflow-hidden mt-0">
    <Ticker />

    <Container>
      <div class="pt-16 pb-12 space-y-12 md:space-y-20 animate show">

        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-neutral-900 pb-10">
          <div class="space-y-4">
            <h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-white uppercase">{regionName}</h1>
            <p class="text-neutral-500 text-xs md:text-sm tracking-[0.3em] uppercase font-light">
              State Desk • {allPosts.length} Reports
            </p>
          </div>
          <div class="flex items-center gap-6 pb-2">
            <a href={`/archives/${regionSlug}`} class="text-[10px] font-bold tracking-[0.3em] uppercase text-red-500 hover:text-white transition-colors border-b border-neutral-900 hover:border-white pb-1">
                View Full ${regionName} Archive
            </a>
            <a href="/local" class="text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-500 hover:text-white transition-colors border-b border-neutral-900 hover:border-white pb-1">
                Back to Regional Hub
            </a>
          </div>
        </div>

        {allPosts.length === 0 ? (
            <div class="py-32 flex flex-col items-center justify-center text-center space-y-8">
                <div class="h-20 w-20 rounded-full border border-neutral-900 flex items-center justify-center bg-neutral-950/50">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-800"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                </div>
                <div class="space-y-2">
                    <h2 class="text-xl font-bold uppercase tracking-[0.2em] text-white">No Reports Found</h2>
                    <p class="text-sm text-neutral-500 font-light max-w-sm mx-auto leading-relaxed">
                        We are currently curating reports for {regionName}. Please check back soon for the latest updates.
                    </p>
                </div>
            </div>
        ) : (
            <>
                {/* TIER 1: STATE HEADLINE MOSAIC */}
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:h-[600px]">
                    {/* Main Large Hero */}
                    {mainHero && (
                        <section class="lg:col-span-8 h-full group relative overflow-hidden rounded-[2rem] md:rounded-[2.5rem] border border-neutral-800 bg-neutral-900/10 shadow-3xl transition-all duration-700 hover:border-neutral-700 hover:bg-neutral-900/30">
                        <a href={`/${mainHero.id.split('/').pop()}`} class="flex flex-col h-full">
                            <div class="relative flex-grow overflow-hidden bg-neutral-900">
                            <img 
                                src={mainHero.data.image || "/assets/fallback.webp"} 
                                alt={mainHero.data.title}
                                class="h-full w-full object-cover transition-transform duration-1000 group-hover:scale-105 opacity-80 group-hover:opacity-100"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-950/20 to-transparent"></div>
                            <div class="absolute top-8 left-8">
                                <span class="rounded-full bg-white text-black px-6 py-2 text-[10px] font-bold tracking-[0.4em] uppercase shadow-2xl">
                                Featured in {regionName}
                                </span>
                            </div>
                            <div class="absolute bottom-10 left-10 right-10 space-y-4">
                                <div class="flex items-center gap-5">
                                    <span class="text-[10px] font-bold tracking-[0.4em] uppercase text-red-500">
                                    Top Story
                                    </span>
                                    <span class="h-1 w-1 rounded-full bg-neutral-600"></span>
                                    <time class="text-[10px] font-medium tracking-[0.2em] text-neutral-400 uppercase">
                                    {mainHero.data.date.toLocaleDateString("en-US", { month: "long", day: "numeric" })}
                                    </time>
                                </div>
                                <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-white leading-tight uppercase">
                                {mainHero.data.title}
                                </h2>
                            </div>
                            </div>
                        </a>
                        </section>
                    )}

                    {/* Secondary Vertical Stack */}
                    <div class="lg:col-span-4 flex flex-col gap-4">
                        {secondaryHeroes.map(post => (
                        <section class="flex-1 group relative overflow-hidden rounded-[2rem] border border-neutral-800 bg-neutral-900/10 transition-all duration-500 hover:border-neutral-700 hover:bg-neutral-900/30 h-[290px]">
                            <a href={`/${post.id.split('/').pop()}`} class="flex flex-col h-full p-8 justify-end relative">
                            <img 
                                src={post.data.image || "/assets/fallback.webp"} 
                                alt={post.data.title}
                                class="absolute inset-0 h-full w-full object-cover transition-transform duration-1000 group-hover:scale-110 opacity-40 group-hover:opacity-60"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 to-transparent"></div>
                            <div class="relative z-10 space-y-3">
                                <span class="text-[9px] font-bold tracking-[0.4em] uppercase text-red-500/80">
                                {post.data.majorTag} Desk
                                </span>
                                <h3 class="text-lg md:text-xl font-bold tracking-tight text-white leading-snug uppercase line-clamp-3">
                                {post.data.title}
                                </h3>
                            </div>
                            </a>
                        </section>
                        ))}
                    </div>
                </div>

                {/* TIER 2: GRID */}
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 pt-12">
                    <div class="lg:col-span-8 space-y-12">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            {gridPosts.map((post) => (
                                <FeedCard
                                    href={`/${post.id.split('/').pop()}`}
                                    date={post.data.date.toLocaleDateString("en-US", { month: "short", day: "2-digit", year: "numeric" })}
                                    title={post.data.title}
                                    description={post.data.description}
                                    image={post.data.image}
                                    category={post.data.category}
                                    region={post.data.region}
                                />
                            ))}
                        </div>
                    </div>

                    <aside class="lg:col-span-4">
                        <SidebarWidgets />
                    </aside>
                </div>
            </>
        )}

      </div>
    </Container>
  </div>
</BlogLayout>
