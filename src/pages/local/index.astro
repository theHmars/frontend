---
import { type CollectionEntry, getCollection } from "astro:content";
import BlogLayout from "@layouts/BlogLayout.astro";
import Container from "@components/Container.astro";
import FeedCard from "@components/FeedCard.astro";
import NewsListRow from "@components/NewsListRow.astro";
import Ticker from "@components/Ticker.astro";
import SidebarWidgets from "@components/SidebarWidgets.astro";
import { REGIONS } from "@consts";

const allLocalPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft && post.data.category === "Local")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// REGIONAL INTELLIGENCE LOGIC
const postsByRegion = REGIONS.map(region => {
  const regionPosts = allLocalPosts.filter(post => post.data.region === region);
  const latestPost = regionPosts[0];
  const isFresh = latestPost && (new Date().getTime() - new Date(latestPost.data.date).getTime() < 48 * 60 * 60 * 1000);
  
  return {
    name: region,
    count: regionPosts.length,
    latest: latestPost,
    isFresh
  };
});

// TIER 1: Top in States (Mosaic Cycling)
const topStates = ["Manipur", "Assam", "Mizoram", "Meghalaya"];
const heroStories = topStates.map(state => 
  allLocalPosts.find(p => p.data.region === state && p.data.image && !p.data.image.includes('fallback.webp'))
).filter((p): p is CollectionEntry<"blog"> => !!p).slice(0, 3);

if (heroStories.length < 3) {
  const existingIds = new Set(heroStories.map(p => p.id));
  const moreHeroes = allLocalPosts.filter(p => !existingIds.has(p.id) && p.data.image && !p.data.image.includes('fallback.webp')).slice(0, 3 - heroStories.length);
  heroStories.push(...moreHeroes);
}

const heroCombos = [];
if (heroStories.length === 3) {
  heroCombos.push({ mainHero: heroStories[0], secondaryHeroes: [heroStories[1], heroStories[2]] });
  heroCombos.push({ mainHero: heroStories[1], secondaryHeroes: [heroStories[2], heroStories[0]] });
  heroCombos.push({ mainHero: heroStories[2], secondaryHeroes: [heroStories[0], heroStories[1]] });
} else if (heroStories.length > 0) {
  heroCombos.push({ mainHero: heroStories[0], secondaryHeroes: heroStories.slice(1) });
}

const heroIds = new Set(heroStories.map(p => p.id));
const remainingPosts = allLocalPosts.filter(p => !heroIds.has(p.id));

// TIER 2: Grid (6)
const gridPosts = remainingPosts.slice(0, 6);

// TIER 3: Recent List
const listPosts = remainingPosts.slice(6, 14);
---

<BlogLayout title="Local Desk" description="Northeast India Regional Hub">
  <div class="bg-neutral-950/50 backdrop-blur-2xl border border-neutral-800 rounded-[2rem] md:rounded-[3rem] shadow-2xl overflow-hidden mt-0">
    <Ticker />

    <Container>
      <div class="pt-16 pb-12 space-y-12 md:space-y-20 animate show">

        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-neutral-900 pb-10">
          <div class="space-y-4">
            <h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-white uppercase">Local Desk</h1>
            <p class="text-neutral-500 text-xs md:text-sm tracking-[0.3em] uppercase font-light">
              Northeast India Hub • {allLocalPosts.length} Reports
            </p>
          </div>
          <div class="pb-2">
            <a href="/archives/local" class="text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-500 hover:text-white transition-colors border-b border-neutral-900 hover:border-white pb-1">
                View Local Archive
            </a>
          </div>
        </div>

        {/* REGIONAL NAVIGATION (STATE CARDS) */}
        <section class="space-y-8">
            <div class="flex items-center gap-4">
                <h2 class="text-[10px] font-bold tracking-[0.4em] uppercase text-red-500">Regional Intelligence</h2>
                <div class="h-px flex-1 bg-neutral-900"></div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                {postsByRegion.map(region => (
                    <a 
                        href={`/local/${region.name.toLowerCase().replace(/ /g, '-')}`} 
                        class="group relative flex flex-col p-6 rounded-[2rem] border border-neutral-900 bg-neutral-950/40 hover:border-red-600/30 hover:bg-neutral-900/50 transition-all duration-500 overflow-hidden"
                    >
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-[10px] font-bold tracking-widest text-neutral-400 group-hover:text-white transition-colors uppercase">
                                {region.name}
                            </span>
                            <div class="flex items-center gap-2">
                                <span class="text-[9px] font-mono text-neutral-700 group-hover:text-red-500 transition-colors">
                                    {region.count.toString().padStart(2, '0')}
                                </span>
                                {region.isFresh && (
                                    <span class="relative flex h-1.5 w-1.5">
                                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
                                        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-red-600"></span>
                                    </span>
                                )}
                            </div>
                        </div>

                        {region.latest ? (
                            <div class="space-y-2 mt-auto">
                                <p class="text-[8px] tracking-[0.2em] uppercase text-neutral-600 font-bold group-hover:text-red-500/50">Latest Update</p>
                                <h3 class="text-xs font-bold text-neutral-500 group-hover:text-neutral-200 line-clamp-2 leading-relaxed transition-colors uppercase">
                                    {region.latest.data.title}
                                </h3>
                            </div>
                        ) : (
                            <p class="text-[9px] text-neutral-800 uppercase tracking-widest italic mt-auto">No recent reports</p>
                        )}

                        <div class="absolute -right-4 -bottom-4 text-neutral-900/10 group-hover:text-red-900/5 transition-colors duration-500 pointer-events-none">
                             <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 12h3v8h14v-8h3L12 2z"/></svg>
                        </div>
                    </a>
                ))}
            </div>
        </section>

        {/* TIER 1: LOCAL HEADLINE MOSAIC (Cycling) */}
        <div id="local-cycle-container" class="relative">
          {heroCombos.map((combo, index) => (
            <div id={`local-hero-set-${index}`} class="local-hero-set grid grid-cols-1 lg:grid-cols-12 gap-4 lg:h-[600px]" style="display: none;">
                {/* Main Large Hero */}
                {combo.mainHero && (
                    <section class="lg:col-span-8 h-full group relative overflow-hidden rounded-[2rem] md:rounded-[2.5rem] border border-neutral-800 bg-neutral-900/10 shadow-3xl transition-all duration-700 hover:border-neutral-700 hover:bg-neutral-900/30">
                        <a href={`/${combo.mainHero.id.split('/').pop()}`} class="flex flex-col h-full">
                            <div class="relative flex-grow overflow-hidden bg-neutral-900">
                            <img 
                                src={combo.mainHero.data.image || "/assets/fallback.webp"} 
                                alt={combo.mainHero.data.title}
                                class="h-full w-full object-cover transition-transform duration-1000 group-hover:scale-105 opacity-80 group-hover:opacity-100"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-950/20 to-transparent"></div>
                            <div class="absolute top-8 left-8">
                                <span class="rounded-full bg-white text-black px-6 py-2 text-[10px] font-bold tracking-[0.4em] uppercase shadow-2xl">
                                State Highlight
                                </span>
                            </div>
                            <div class="absolute bottom-10 left-10 right-10 space-y-4">
                                <div class="flex items-center gap-5">
                                    <span class="text-[10px] font-bold tracking-[0.4em] uppercase text-red-500">
                                    {combo.mainHero.data.region} Desk
                                    </span>
                                    <span class="h-1 w-1 rounded-full bg-neutral-600"></span>
                                    <time class="text-[10px] font-medium tracking-[0.2em] text-neutral-400 uppercase">
                                    {combo.mainHero.data.date.toLocaleDateString("en-US", { month: "long", day: "numeric" })}
                                    </time>
                                </div>
                                <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-white leading-tight uppercase">
                                {combo.mainHero.data.title}
                                </h2>
                            </div>
                            </div>
                        </a>
                    </section>
                )}

                {/* Secondary Vertical Stack */}
                <div class="lg:col-span-4 flex flex-col gap-4">
                    {combo.secondaryHeroes.map(post => (
                    <section class="flex-1 group relative overflow-hidden rounded-[2rem] border border-neutral-800 bg-neutral-900/10 transition-all duration-500 hover:border-neutral-700 hover:bg-neutral-900/30 h-[290px]">
                        <a href={`/${post.id.split('/').pop()}`} class="flex flex-col h-full p-8 justify-end relative">
                        <img 
                            src={post.data.image || "/assets/fallback.webp"} 
                            alt={post.data.title}
                            class="absolute inset-0 h-full w-full object-cover transition-transform duration-1000 group-hover:scale-110 opacity-40 group-hover:opacity-60"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 to-transparent"></div>
                        <div class="relative z-10 space-y-3">
                            <span class="text-[9px] font-bold tracking-[0.4em] uppercase text-red-500/80">
                            Top in {post.data.region}
                            </span>
                            <h3 class="text-lg md:text-xl font-bold tracking-tight text-white leading-snug uppercase line-clamp-3">
                            {post.data.title}
                            </h3>
                        </div>
                        </a>
                    </section>
                    ))}
                </div>
            </div>
          ))}
        </div>

        <script is:inline>
          (function() {
            try {
              let cycle = parseInt(sessionStorage.getItem('localHeroCycle') || '-1');
              const totalCombos = document.querySelectorAll('.local-hero-set').length;
              if (totalCombos > 0) {
                cycle = (cycle + 1) % totalCombos;
                sessionStorage.setItem('localHeroCycle', cycle);
                const el = document.getElementById('local-hero-set-' + cycle);
                if (el) {
                  el.style.display = 'grid';
                }
              }
            } catch(e) {
              const first = document.querySelector('.local-hero-set');
              if(first) first.style.display = 'grid';
            }
          })();
        </script>

        {/* TIER 2: CATEGORY GRID */}
        {gridPosts.length > 0 && (
          <section class="space-y-10">
            <div class="flex items-center justify-between border-b border-neutral-900 pb-4">
              <h2 class="text-[10px] font-bold tracking-[0.5em] uppercase text-neutral-500">Latest in Local</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {gridPosts.map((post) => (
                <FeedCard
                  href={`/${post.id.split('/').pop()}`}
                  date={post.data.date.toLocaleDateString("en-US", { month: "short", day: "2-digit", year: "numeric" })}
                  title={post.data.title}
                  description={post.data.description}
                  image={post.data.image}
                  category={post.data.category}
                  region={post.data.region}
                />
              ))}
            </div>
          </section>
        )}

        {/* TIER 3: LIST & SIDEBAR */}
        <section class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            <div class="lg:col-span-8 space-y-10">
                <div class="flex items-center justify-between border-b border-neutral-900 pb-4">
                    <h2 class="text-[10px] font-bold tracking-[0.5em] uppercase text-neutral-500">More Reports</h2>
                </div>
                <ul class="space-y-4">
                    {listPosts.map((post) => (
                        <NewsListRow 
                            href={`/${post.id.split('/').pop()}`}
                            date={post.data.date.toLocaleDateString("en-US", { month: "short", day: "2-digit" })}
                            title={post.data.title}
                            image={post.data.image}
                            category={post.data.category}
                        />
                    ))}
                </ul>
            </div>

            <aside class="lg:col-span-4 space-y-12">
                <SidebarWidgets />
            </aside>
        </section>

      </div>
    </Container>
  </div>
</BlogLayout>
