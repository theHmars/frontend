{
  "name": "batchnode",
  "type": "module",
  "version": "0.0.2",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "if [ \"$RENDER\" = \"true\" ]; then echo 'Fetching production content...'; git clone https://${GITHUB_TOKEN}@github.com/theHmars/content.git temp-content && rm -rf src/content/news && mkdir -p src/content/news && cp -r temp-content/markdown/* src/content/news/ && rm -rf temp-content; else echo 'Local build: using local content symlinks'; fi",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.2",
    "@astrojs/mdx": "4.0.8",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "3.2.1",
    "@chenglou/pretext": "^0.0.6",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@supabase/supabase-js": "^2.107.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/three": "^0.183.1",
    "animejs": "^4.4.1",
    "astro": "^5.18.2",
    "astro-pagefind": "^2.0.0",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13",
    "three": "^0.183.2",
    "typescript": "^5.7.2",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.18",
    "pagefind": "^1.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.14"
  }
}
